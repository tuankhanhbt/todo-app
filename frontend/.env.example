# Sao chép file này thành .env rồi điền giá trị (lấy từ output của `cdk deploy`).
VITE_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com
VITE_COGNITO_AUTHORITY=https://cognito-idp.<region>.amazonaws.com/<userPoolId>
VITE_COGNITO_CLIENT_ID=<userPoolClientId>
VITE_COGNITO_DOMAIN=https://<domainPrefix>.auth.<region>.amazoncognito.com
